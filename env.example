# Kopiraj ovu datoteku u .env i upiši svoje ključeve
# cp .env.example .env
#
# VAŽNO: .env datoteku NIKAD ne stavljaj na GitHub!
# Ova .env.example datoteka je sigurna za dijeljenje jer ne sadrži prave ključeve.

# OMDb API ključ
# Besplatna registracija na: http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# ngrok auth token
# Besplatna registracija na: https://ngrok.com/
NGROK_TOKEN=your_ngrok_token_here
